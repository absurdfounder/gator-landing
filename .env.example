# Firebase — set in Netlify site env (server runtime only, served via /api/firebase-config).
# Do NOT use NEXT_PUBLIC_FIREBASE_* in production — Next inlines those into build output.
# Copy to .env.local for local dev.
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_DATABASE_URL=
