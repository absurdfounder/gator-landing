# Firebase — optional in Netlify; login works via shared defaults if unset.
# Prefer FIREBASE_* (server runtime, served via /api/firebase-config).
# NEXT_PUBLIC_FIREBASE_* also works and is inlined into the client bundle at build time.
# Copy to .env.local for local dev (values from Trooper ai-copilot-104 project).
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_DATABASE_URL=
