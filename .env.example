# Firebase — set FIREBASE_* in Netlify (Project configuration → Environment variables).
# Served at runtime via /api/firebase-config; do not hardcode keys in source.
# Copy to .env.local for local dev (values from Trooper ai-copilot-104 project).
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_DATABASE_URL=
