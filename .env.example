# Firebase — fetchkitty-app project (Gator / askgator.app auth).
# Set FIREBASE_* in Netlify (Project configuration → Environment variables).
# Served at runtime via /api/firebase-config. Copy to .env.local for local dev.
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
